    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "wrangler": "^3.109.2"
  }
